.page {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 220rpx;
}

.serif { font-family: "Songti SC", "STSong", "Noto Serif SC", serif; }
.mono  { font-family: "SF Mono", "JetBrains Mono", "Menlo", ui-monospace, monospace; }

/* ===== 顶部金色滚动进度条 ===== */
.scroll-progress {
  position: sticky; top: 0; left: 0; right: 0;
  height: 3rpx; z-index: 100; pointer-events: none; background: transparent;
}
.scroll-progress__fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gold) 0%, var(--gold-hi) 100%);
  box-shadow: 0 0 12rpx var(--gold-hi);
  transition: width 0.05s linear;
}

/* ===== V3 POSTER HERO ===== */
.poster-hero {
  position: relative;
  background: #0c1f3d;
}
.poster-hero__img-wrap {
  position: relative;
  width: 100%;
  background: #0c1f3d;
  overflow: hidden;
}
.poster-hero__img {
  width: 100%;
  display: block;
}
.poster-hero__fade {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 120rpx;
  background: linear-gradient(180deg, rgba(246,248,252,0) 0%, var(--bg) 100%);
  pointer-events: none;
}
.poster-hero__foot {
  padding: 18rpx 44rpx 24rpx;
  background: var(--bg);
  display: flex; align-items: center; justify-content: space-between;
  gap: 20rpx;
}
.poster-hero__chip {
  font-size: 20rpx;
  color: var(--muted);
  letter-spacing: 6rpx;
}
.poster-hero__hint {
  font-size: 22rpx;
  color: #8496b3;
  letter-spacing: 0.6rpx;
}
.poster-countdown {
  position: absolute;
  top: 24rpx; right: 24rpx;
  z-index: 5;
  padding: 8rpx 24rpx;
  border-radius: 36rpx;
  background: rgba(0,0,0,0.42);
  color: var(--gold-hi);
  font-size: 22rpx;
  letter-spacing: 1rpx;
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
}

/* ===== 报名状态横幅 ===== */
.reg-banner {
  margin: 24rpx 36rpx 0;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  display: flex; align-items: center; gap: 20rpx;
  background: linear-gradient(90deg, var(--warm-bg) 0%, var(--warm-bg-2) 100%);
  border: 1rpx solid rgba(107,76,30,0.16);
  box-shadow: 0 8rpx 24rpx rgba(107,76,30,0.08);
}
.reg-banner__dot {
  width: 32rpx; height: 32rpx; border-radius: 50%; flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(255,255,255,0.6);
}
.reg-banner--pending  .reg-banner__dot { background: #c9a24a; }
.reg-banner--approved .reg-banner__dot { background: #3d8b5e; }
.reg-banner--rejected .reg-banner__dot { background: #c25450; }
.reg-banner__text {
  font-size: 26rpx; color: var(--warm-ink);
  font-weight: 500; letter-spacing: 0.5rpx;
}

/* ===== SPEAKER HERO（v3） ===== */
.speaker-hero-wrap { padding: 40rpx 36rpx 0; }
.speaker-hero {
  position: relative;
  border-radius: 36rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #0c1f3d 0%, #14305a 55%, #1a3a78 100%);
  box-shadow: 0 40rpx 80rpx rgba(10,25,55,0.32);
  min-height: 480rpx;
  display: flex;
  isolation: isolate;
}
.speaker-hero__star1, .speaker-hero__star2 {
  position: absolute;
  width: 20rpx; height: 20rpx;
  background: var(--gold-hi);
  opacity: 0.6;
  clip-path: polygon(50% 0%,58% 42%,100% 50%,58% 58%,50% 100%,42% 58%,0% 50%,42% 42%);
}
.speaker-hero__star1 { left: 24rpx; top: 28rpx; }
.speaker-hero__star2 { left: 52rpx; top: 168rpx; width: 14rpx; height: 14rpx; opacity: 0.4; }

.speaker-hero__text {
  flex: 1; min-width: 0;
  padding: 40rpx 8rpx 40rpx 44rpx;
  display: flex; flex-direction: column; justify-content: center;
  position: relative; z-index: 2;
}
.speaker-hero__kicker {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: var(--gold-hi);
  margin-bottom: 16rpx;
  font-weight: 500;
}
.speaker-hero__name {
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  line-height: 1.1;
}
.speaker-hero__title {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}
.speaker-hero__quote {
  margin-top: 32rpx;
  padding: 20rpx 24rpx 20rpx 28rpx;
  border-left: 4rpx solid var(--gold-hi);
  background: linear-gradient(90deg, rgba(233,185,73,0.10) 0%, rgba(233,185,73,0) 100%);
}
.speaker-hero__bio {
  font-size: 27rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1.45;
}
.speaker-hero__org {
  font-size: 22rpx;
  color: rgba(255,255,255,0.62);
  margin-top: 8rpx;
  line-height: 1.5;
}

.speaker-hero__photo {
  width: 336rpx;
  flex-shrink: 0;
  position: relative;
  align-self: stretch;
}
.speaker-hero__photo-mask {
  position: absolute;
  inset: 0;
  z-index: 2;
  background: linear-gradient(90deg, rgba(12,31,61,0.92) 0%, rgba(12,31,61,0.35) 22%, rgba(12,31,61,0) 50%);
  pointer-events: none;
}
.speaker-hero__photo-img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: 54% 8%;
}

/* ===== v3 hero subtitle ===== */
.hero-subtitle {
  padding: 44rpx 44rpx 0;
  display: flex; align-items: flex-start; gap: 20rpx;
}
.hero-subtitle__star {
  margin-top: 14rpx;
  width: 22rpx; height: 22rpx; flex-shrink: 0;
  background: var(--gold);
  clip-path: polygon(50% 0%,58% 42%,100% 50%,58% 58%,50% 100%,42% 58%,0% 50%,42% 42%);
}
.hero-subtitle__col { flex: 1; }
.hero-subtitle__l1 {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.55;
}
.hero-subtitle__l2 {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-soft);
  margin-top: 8rpx;
  line-height: 1.55;
}

/* ===== FOUR QUESTIONS ===== */
.four-q-wrap { padding: 52rpx 44rpx 0; }
.four-q {
  background: linear-gradient(180deg, #0f2855 0%, #1a3a78 100%);
  border-radius: 36rpx;
  padding: 36rpx 36rpx 44rpx;
  position: relative;
  overflow: hidden;
}
.four-q__glow {
  position: absolute;
  right: -32rpx; top: -32rpx;
  width: 220rpx; height: 220rpx;
  border-radius: 110rpx;
  background: radial-gradient(circle, rgba(233,185,73,0.22) 0%, transparent 70%);
  pointer-events: none;
}
.four-q__kicker {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: var(--gold-hi);
  margin-bottom: 16rpx;
}
.four-q__title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 28rpx;
  line-height: 1.35;
}
.four-q__list { display: flex; flex-direction: column; }
.four-q__row {
  display: flex; gap: 24rpx; align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.16);
}
.four-q__row--first { border-top: 1rpx solid rgba(255,255,255,0.16); }
.four-q__num {
  font-size: 20rpx;
  color: var(--gold-hi);
  font-weight: 600;
  letter-spacing: 2rpx;
  padding-top: 6rpx;
  flex-shrink: 0;
}
.four-q__text {
  flex: 1;
  font-size: 27rpx;
  color: #f1f5fb;
  line-height: 1.55;
}

/* ===== SECTIONS ===== */
.section { padding: 52rpx 44rpx 0; }
.section-top { padding-top: 52rpx; }
.section-kicker {
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 6rpx;
  margin-bottom: 12rpx;
  text-transform: uppercase;
}
.section-title {
  font-size: 36rpx;
  color: var(--ink);
  font-weight: 700;
  margin-bottom: 28rpx;
}

/* ===== OPENING PITCH ===== */
.opening-title {
  font-size: 38rpx;
  font-weight: 500;
  color: var(--ink);
  line-height: 1.65;
  letter-spacing: 1rpx;
}
.opening-body {
  font-size: 26rpx;
  color: var(--text-soft);
  margin-top: 28rpx;
  line-height: 1.8;
}
.opening-para {
  font-size: 26rpx;
  color: var(--text-soft);
  line-height: 1.8;
}
.opening-para + .opening-para { margin-top: 24rpx; }
.opening-accent { color: var(--ink); font-weight: 500; }

/* ===== POINT CARDS ===== */
.points { display: flex; flex-direction: column; gap: 20rpx; }
.point-card {
  background: var(--card);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid var(--divider);
  display: flex; gap: 24rpx; align-items: flex-start;
}
.point-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 20rpx;
  background: rgba(201,162,74,0.10);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.ico { width: 40rpx; height: 40rpx; position: relative; }

/* v3 icons — CSS 几何近似 */
.ico-syringe {
  display: block;
}
.ico-syringe__needle {
  position: absolute; left: 6rpx; top: 6rpx;
  width: 16rpx; height: 4rpx;
  background: var(--gold);
  transform: rotate(-45deg);
  transform-origin: 0 50%;
  border-radius: 2rpx;
}
.ico-syringe__body {
  position: absolute; left: 12rpx; top: 12rpx;
  width: 22rpx; height: 10rpx;
  background: var(--gold);
  transform: rotate(-45deg);
  transform-origin: 0 50%;
  border-radius: 2rpx;
}
.ico-syringe__plunger {
  position: absolute; right: 0; bottom: 0;
  width: 8rpx; height: 8rpx;
  background: var(--gold);
  border-radius: 50%;
}

.ico-skinheart {
  display: flex; align-items: center; justify-content: center;
}
.ico-skinheart__heart {
  width: 24rpx; height: 24rpx;
  background: var(--gold);
  transform: rotate(-45deg);
  position: relative;
}
.ico-skinheart__heart::before,
.ico-skinheart__heart::after {
  content: '';
  position: absolute;
  width: 24rpx; height: 24rpx;
  background: var(--gold);
  border-radius: 50%;
}
.ico-skinheart__heart::before { top: -12rpx; left: 0; }
.ico-skinheart__heart::after { top: 0; right: -12rpx; }
.ico-skinheart__wave {
  position: absolute; bottom: 4rpx; left: 4rpx; right: 4rpx;
  height: 2rpx;
  background: var(--gold);
  opacity: 0.5;
}

.ico-tangle {
  display: flex; flex-direction: column; justify-content: space-around;
  padding: 4rpx 0;
}
.ico-tangle__l1, .ico-tangle__l2, .ico-tangle__l3 {
  height: 3rpx;
  border-radius: 2rpx;
  background: var(--gold);
}
.ico-tangle__l1 { width: 100%; transform: scaleX(1); }
.ico-tangle__l2 { width: 80%; transform: translateX(20%); }
.ico-tangle__l3 { width: 90%; }

.ico-self {
  display: flex; flex-direction: column; align-items: center; justify-content: flex-start;
  padding-top: 4rpx;
}
.ico-self__head {
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: var(--gold);
}
.ico-self__body {
  width: 22rpx; height: 18rpx;
  margin-top: 4rpx;
  border-radius: 11rpx 11rpx 4rpx 4rpx;
  background: var(--gold);
}

/* legacy v2 icons */
.ico-lanes { display: flex; flex-direction: column; justify-content: space-between; padding: 4rpx 0; }
.ico-lane { height: 2rpx; background: var(--gold); position: relative; border-radius: 1rpx; }
.ico-lane:nth-child(1) { width: 100%; }
.ico-lane:nth-child(2) { width: 70%; }
.ico-lane:nth-child(3) { width: 85%; }
.ico-dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: var(--gold); position: absolute; right: -4rpx; top: 50%; transform: translateY(-50%); }

.ico-footprint { }
.ico-foot { position: absolute; width: 12rpx; height: 16rpx; border-radius: 50% 50% 40% 40%; background: var(--gold); }
.ico-foot--l1 { left: 4rpx;  top: 4rpx; }
.ico-foot--r1 { left: 22rpx; top: 10rpx; }
.ico-foot--l2 { left: 6rpx;  top: 22rpx; }
.ico-foot--r2 { left: 24rpx; top: 26rpx; }

.ico-compass { border: 2rpx solid var(--gold); border-radius: 50%; }
.ico-compass-needle {
  position: absolute; left: 50%; top: 50%;
  width: 4rpx; height: 26rpx;
  background: linear-gradient(180deg, var(--gold) 0%, var(--gold) 50%, transparent 50%, transparent 100%);
  transform: translate(-50%, -50%) rotate(35deg);
  border-radius: 2rpx;
}

.point-body { flex: 1; min-width: 0; }
.point-head { display: flex; align-items: baseline; gap: 16rpx; }
.point-num { font-size: 20rpx; color: var(--gold); font-weight: 600; letter-spacing: 2rpx; flex-shrink: 0; }
.point-title { font-size: 30rpx; font-weight: 700; color: var(--ink); line-height: 1.3; flex: 1; min-width: 0; }
.point-sub { font-size: 24rpx; color: var(--muted); margin-top: 4rpx; }
.point-text { margin-top: 16rpx; }
.point-para { font-size: 25rpx; color: var(--text-soft); line-height: 1.65; }
.point-para + .point-para { margin-top: 16rpx; }

/* ===== WALL TEASER ===== */
.wall-teaser {
  background: var(--card);
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid var(--divider);
  display: flex; gap: 28rpx; align-items: center;
}
.wall-teaser__thumb {
  width: 112rpx; height: 84rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #0f2855 0%, #1a3a78 100%);
  padding: 12rpx;
  display: flex; flex-direction: column; gap: 6rpx;
  position: relative; overflow: hidden;
}
.wall-teaser__line { height: 6rpx; border-radius: 4rpx; }
.wall-teaser__line--w  { background: #fff; opacity: 0.8; }
.wall-teaser__line--g  { background: var(--gold-hi); }
.wall-teaser__line--w2 { background: #fff; opacity: 0.6; width: 70%; }
.wall-teaser__line--g2 { background: var(--gold-hi); opacity: 0.8; width: 85%; }

.wall-teaser__body { flex: 1; min-width: 0; }
.wall-teaser__title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
  display: flex; align-items: center; gap: 14rpx;
}
.wall-teaser__new {
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  background: var(--gold-hi);
  color: #3d2a08;
  letter-spacing: 2rpx;
}
.wall-teaser__sub {
  font-size: 22rpx;
  color: var(--muted-soft);
  margin-top: 8rpx;
  line-height: 1.5;
}

/* ===== INFO CARD ===== */
.info-card {
  background: var(--card);
  border-radius: 32rpx;
  padding: 32rpx 36rpx;
  border: 1rpx solid var(--divider);
}
.info-row { display: flex; align-items: flex-start; gap: 28rpx; padding: 18rpx 0; position: relative; }
.info-row:not(:last-child)::after { content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 1rpx; background: #e9eef6; }
.info-label { font-size: 22rpx; color: #8496b3; letter-spacing: 4rpx; width: 68rpx; padding-top: 6rpx; flex-shrink: 0; }
.info-col { flex: 1; }
.info-value { font-size: 29rpx; color: var(--ink); font-weight: 500; }
.info-sub { font-size: 23rpx; color: var(--muted-soft); margin-top: 4rpx; }

/* ===== MENU CARD ===== */
.menu-card {
  background: linear-gradient(135deg, var(--warm-bg) 0%, var(--warm-bg-2) 100%);
  border-radius: 32rpx;
  padding: 32rpx 36rpx;
  border: 1rpx solid #e8dcc0;
}
.menu-title { font-size: 34rpx; font-weight: 700; color: var(--warm-ink); line-height: 1.35; }
.menu-sub { font-size: 24rpx; color: var(--warm-text); margin-top: 8rpx; font-style: italic; }
.menu-chip {
  display: inline-flex; align-items: center; gap: 12rpx;
  padding: 12rpx 24rpx;
  border-radius: 200rpx;
  background: rgba(107,76,30,0.08);
  border: 1rpx solid rgba(107,76,30,0.18);
  font-size: 23rpx;
  color: var(--warm-ink);
  margin-top: 24rpx;
}
.menu-chip__icon { width: 22rpx; height: 22rpx; border: 2rpx solid var(--warm-ink); border-radius: 50%; position: relative; }
.menu-chip__icon::after { content: ''; position: absolute; left: -4rpx; right: -4rpx; top: 50%; height: 2rpx; background: var(--warm-ink); transform: translateY(-50%) rotate(-45deg); }

.menu-sep { height: 1rpx; background: #e0d2b0; margin: 24rpx 0; }
.menu-list { display: flex; flex-direction: column; gap: 16rpx; }
.menu-row { display: flex; align-items: center; gap: 20rpx; }
.menu-name { font-size: 29rpx; color: #5a3f14; font-weight: 600; flex: 1; }
.menu-tag { font-size: 21rpx; color: var(--warm-text); letter-spacing: 2rpx; }
.menu-foot { font-size: 23rpx; color: var(--warm-text); margin-top: 24rpx; line-height: 1.55; font-style: italic; }

/* Gia 备注小卡 */
.gia-card {
  margin-top: 28rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: rgba(107,76,30,0.06);
  border: 1rpx dashed rgba(107,76,30,0.28);
  display: flex; gap: 24rpx; align-items: flex-start;
}
.gia-card__badge {
  width: 52rpx; height: 52rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-hi) 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(107,76,30,0.25);
  flex-shrink: 0;
}
.gia-card__body { flex: 1; min-width: 0; font-size: 24rpx; color: var(--warm-ink); line-height: 1.65; }
.gia-card__main { font-weight: 600; }
.gia-card__sub { color: var(--warm-text); margin-top: 4rpx; }
.gia-card__sub-strong { color: var(--warm-ink); font-weight: 600; }

/* ===== WHAT IS DCT ===== */
.dct-head { display: flex; align-items: center; gap: 24rpx; margin-bottom: 20rpx; }
.dct-logo { width: 96rpx; height: 96rpx; border-radius: 48rpx; flex-shrink: 0; }
.dct-head-title { font-size: 38rpx; font-weight: 700; color: var(--ink); line-height: 1.25; margin-top: 4rpx; }
.dct-tagline { font-size: 25rpx; color: var(--text-soft); font-style: italic; line-height: 1.65; }
.dct-latin { font-size: 23rpx; color: var(--muted-soft); margin-top: 12rpx; letter-spacing: 0.6rpx; }
.dct-body { font-size: 26rpx; color: var(--text); margin-top: 28rpx; line-height: 1.75; }
.dct-body-line2 { margin-top: 4rpx; }
.dct-body-para { line-height: 1.75; }
.dct-invite { font-size: 28rpx; color: var(--navy); margin-top: 28rpx; font-weight: 600; letter-spacing: 1rpx; }

/* ===== RULES ENTRY ===== */
.rules-entry {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx;
  background: var(--card);
  border-radius: 28rpx;
  border: 1rpx solid var(--divider);
}
.rules-entry-title { font-size: 28rpx; font-weight: 600; color: var(--ink); }
.rules-entry-sub { font-size: 23rpx; color: var(--muted-soft); margin-top: 4rpx; }
.chevron {
  width: 18rpx; height: 18rpx;
  border-right: 4rpx solid #a0acc0;
  border-top: 4rpx solid #a0acc0;
  transform: rotate(45deg);
}

/* ===== CTA ===== */
.cta-wrap { padding: 48rpx 36rpx 60rpx; }
.cta {
  width: 100%;
  height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(180deg, var(--navy-soft) 0%, var(--navy) 100%);
  color: #fff; border: none;
  font-size: 32rpx; font-weight: 600; letter-spacing: 8rpx;
  box-shadow: 0 16rpx 44rpx rgba(26,58,120,0.32);
  display: flex; align-items: center; justify-content: center; gap: 20rpx;
  padding: 0;
}
.cta::after { border: none; }
.cta-hover { opacity: 0.92; transform: scale(0.99); }
.cta-text { color: #fff; font-size: 32rpx; font-weight: 600; letter-spacing: 8rpx; }
.cta-sub { margin-top: 20rpx; text-align: center; font-size: 23rpx; color: var(--muted-soft); }
.cta-sub-accent { color: var(--navy-soft); }

.tap-hover { background: #f4f7fc; }

/* ===== STICKY CTA ===== */
.sticky-cta {
  position: fixed;
  bottom: 36rpx; left: 32rpx; right: 32rpx;
  z-index: 80;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border: 1rpx solid var(--divider);
  border-radius: 60rpx;
  box-shadow: 0 24rpx 60rpx rgba(15,40,85,0.18);
  padding: 16rpx 16rpx 16rpx 36rpx;
  opacity: 0;
  transform: translateY(40rpx);
  pointer-events: none;
  transition: opacity 280ms cubic-bezier(0.22,1,0.36,1), transform 280ms cubic-bezier(0.22,1,0.36,1);
}
.sticky-cta.is-visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
.sticky-cta__inner { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.sticky-cta__info { flex: 1; min-width: 0; }
.sticky-cta__kicker { font-size: 20rpx; color: var(--muted); letter-spacing: 4rpx; }
.sticky-cta__price { margin-top: 4rpx; display: flex; align-items: baseline; gap: 8rpx; color: var(--ink); }
.sticky-cta__num { font-size: 36rpx; font-weight: 700; }
.sticky-cta__unit { font-size: 22rpx; color: var(--muted); }
.sticky-cta__hint { font-size: 20rpx; color: var(--muted-soft); margin-left: 4rpx; }
.sticky-cta__btn {
  height: 88rpx;
  padding: 0 36rpx;
  border-radius: 44rpx;
  background: linear-gradient(180deg, var(--navy-soft) 0%, var(--navy) 100%);
  color: #fff; font-size: 28rpx; font-weight: 600; letter-spacing: 4rpx;
  display: flex; align-items: center; gap: 12rpx;
  flex-shrink: 0;
}
.sticky-cta__star { width: 20rpx; height: 20rpx; }

/* ===== STAR BULLET ===== */
.star-bullet {
  width: 20rpx; height: 20rpx;
  flex-shrink: 0;
  clip-path: polygon(50% 0%,58% 42%,100% 50%,58% 58%,50% 100%,42% 58%,0% 50%,42% 42%);
}
.star-gold  { background: var(--gold); }
.star-brown { background: #b8903a; width: 18rpx; height: 18rpx; }
.star-cta   { background: var(--gold-hi); width: 24rpx; height: 24rpx; }
