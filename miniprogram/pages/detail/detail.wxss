.page {
  background: #f6f8fc;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.hero {
  padding: 36rpx 44rpx 56rpx;
}
.hero-eyebrow {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: rgba(255,255,255,0.88);
  margin-bottom: 16rpx;
}
.hero-title {
  font-size: 64rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(10,30,60,0.3);
}
.hero-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.78);
  margin-top: 16rpx;
  line-height: 1.6;
}

.section {
  padding: 44rpx 44rpx 0;
}
.section-kicker {
  font-size: 22rpx;
  color: #55709a;
  letter-spacing: 6rpx;
  text-transform: uppercase;
  margin-bottom: 20rpx;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  border: 1rpx solid #e3e9f3;
}

.flow-card {
  padding: 16rpx 0;
}
.flow-row {
  display: flex;
  gap: 32rpx;
  padding: 24rpx 36rpx;
  align-items: center;
  border-bottom: 1rpx solid #eef2f8;
}
.flow-row:last-child { border-bottom: none; }
.flow-time {
  font-size: 26rpx;
  font-weight: 500;
  color: #2c5ca0;
  width: 92rpx;
  flex-shrink: 0;
}
.flow-label {
  font-size: 28rpx;
  color: #0f2855;
}

/* info card */
.info-card {
  padding: 32rpx 36rpx;
}
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  padding: 8rpx 0;
}
.info-label {
  font-size: 22rpx;
  color: #8496b3;
  letter-spacing: 4rpx;
  width: 68rpx;
  padding-top: 6rpx;
  flex-shrink: 0;
}
.info-col { flex: 1; }
.info-value {
  font-size: 29rpx;
  color: #0f2855;
  font-weight: 500;
}
.info-sub {
  font-size: 23rpx;
  color: #6b7a91;
  margin-top: 4rpx;
}
.sep {
  height: 1rpx;
  background: #e9eef6;
  margin: 20rpx 0;
}

/* rules */
.rules-intro {
  font-size: 25rpx;
  color: #3d5f94;
  margin-top: 12rpx;
  margin-bottom: 20rpx;
  font-style: italic;
}
.rules-card {
  padding: 8rpx 0;
}
.rules-row {
  display: flex;
  gap: 28rpx;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #eef2f8;
  align-items: flex-start;
}
.rules-row:last-child { border-bottom: none; }
.rule-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #eaf0f9;
  color: #2c5ca0;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.rule-body { flex: 1; min-width: 0; }
.rule-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.rule-k {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f2855;
}
.rule-v {
  font-size: 25rpx;
  color: #55709a;
  margin-top: 4rpx;
  line-height: 1.6;
}
.rule-tag {
  font-size: 18rpx;
  letter-spacing: 2rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}
.rule-tag--head { background: #e9b949; color: #3d2a08; }
.rule-tag--vol  { background: rgba(44,92,160,0.12); color: #1a3a78; }

.rules-row--head {
  background: linear-gradient(90deg, rgba(233,185,73,0.16) 0%, rgba(233,185,73,0.04) 100%);
}
.rules-row--head .rule-k { color: #6b4c1e; }
.rules-row--head .rule-v { color: #8a6a2e; }
.rule-star {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #e9b949 0%, #c9a24a 100%);
  color: #fff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 10rpx rgba(201,162,74,0.35);
}

.rules-row--wall {
  background: linear-gradient(90deg, rgba(44,92,160,0.08) 0%, rgba(44,92,160,0.02) 100%);
}
.rules-row--wall .rule-num {
  background: rgba(44,92,160,0.16);
  color: #1a3a78;
}

/* chips */
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}
.chip {
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #fff;
  color: #2c5ca0;
  border: 1rpx solid #c9d4e6;
}

/* cta */
.cta-wrap {
  padding: 48rpx 36rpx 60rpx;
}
.cta {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(180deg, #2c5ca0 0%, #1a3a78 100%);
  color: #fff;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  box-shadow: 0 16rpx 44rpx rgba(26,58,120,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}
.cta::after { border: none; }
.cta-hover { opacity: 0.92; }
.cta-text { color: #fff; }
