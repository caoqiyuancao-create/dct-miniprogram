.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 96rpx;
}

.home-hero {
  padding: 72rpx 44rpx 0;
  text-align: center;
}

.logo-shell {
  width: 264rpx;
  height: 264rpx;
  border-radius: 50%;
  margin: 0 auto 40rpx;
  padding: 16rpx;
  background: #fff;
  box-shadow: 0 40rpx 80rpx rgba(15,40,85,0.22), 0 0 0 8rpx rgba(255,255,255,0.9);
  overflow: hidden;
}

.logo-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.brand-line {
  font-size: 22rpx;
  letter-spacing: 12rpx;
  color: var(--navy);
  opacity: 0.75;
  margin-bottom: 20rpx;
}

.home-title {
  font-size: 68rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 8rpx;
  line-height: 1.15;
}

.slogan-box {
  margin-top: 32rpx;
  height: 56rpx;
  position: relative;
  overflow: hidden;
}

.slogan-item {
  position: absolute;
  inset: 0;
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 0.6s ease, transform 0.6s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  font-size: 25rpx;
  color: var(--text-soft);
  letter-spacing: 2rpx;
}

.slogan-item.is-active {
  opacity: 1;
  transform: translateY(0);
}

.star-bullet {
  width: 16rpx;
  height: 16rpx;
  background: var(--gold);
  flex-shrink: 0;
  clip-path: polygon(50% 0%, 58% 42%, 100% 50%, 58% 58%, 50% 100%, 42% 58%, 0% 50%, 42% 42%);
}

.announcement {
  margin-top: 56rpx;
  height: 80rpx;
  padding: 20rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.8);
  border: 1rpx solid rgba(15,40,85,0.1);
  backdrop-filter: blur(28rpx);
  -webkit-backdrop-filter: blur(28rpx);
  display: flex;
  align-items: center;
  gap: 20rpx;
  overflow: hidden;
}

.ann-badge {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 19rpx;
  letter-spacing: 3rpx;
  font-weight: 600;
}

.ann-badge--signup { background: var(--gold); }
.ann-badge--info { background: var(--navy-soft); }

.ann-copy {
  flex: 1;
  height: 36rpx;
  min-width: 0;
  position: relative;
}

.ann-item {
  position: absolute;
  inset: 0;
  opacity: 0;
  transform: translateY(12rpx);
  transition: opacity 0.5s ease, transform 0.5s ease;
  font-size: 25rpx;
  color: var(--ink);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: left;
}

.ann-item.is-active {
  opacity: 1;
  transform: translateY(0);
}

.ann-date {
  color: var(--muted-soft);
  margin-left: 16rpx;
  font-size: 22rpx;
}

.entries {
  padding: 56rpx 36rpx 0;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.entry-row {
  display: flex;
  gap: 24rpx;
}

.entry-card {
  position: relative;
  overflow: hidden;
  border-radius: 36rpx;
  padding: 32rpx;
  border: 1rpx solid var(--divider);
  background: #fff;
}

.entry-card--primary {
  min-height: 250rpx;
  padding: 36rpx 40rpx;
  color: #fff;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-soft) 100%);
  border: none;
  box-shadow: 0 20rpx 48rpx rgba(26,58,120,0.28);
}

.entry-card--secondary {
  flex: 1;
  min-height: 192rpx;
  box-shadow: 0 4rpx 16rpx rgba(15,40,85,0.04);
}

.entry-glow {
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(233,185,73,0.28) 0%, transparent 70%);
}

.entry-kicker {
  position: relative;
  z-index: 1;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: var(--muted);
  margin-bottom: 12rpx;
}

.entry-card--primary .entry-kicker {
  color: var(--gold-hi);
}

.entry-title {
  position: relative;
  z-index: 1;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
  color: inherit;
}

.entry-title--small {
  color: var(--ink);
  font-size: 36rpx;
}

.entry-body {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--muted);
}

.entry-card--primary .entry-body {
  color: rgba(255,255,255,0.82);
  padding-right: 96rpx;
}

.entry-meta {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: rgba(255,255,255,0.65);
}

.entry-arrow {
  position: absolute;
  right: 36rpx;
  bottom: 36rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  border: 1rpx solid rgba(255,255,255,0.3);
}

.entry-arrow::after {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 16rpx;
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid #fff;
  border-right: 4rpx solid #fff;
  transform: rotate(45deg);
}

.entry-hover {
  opacity: 0.86;
  transform: translateY(2rpx);
}

.home-footer {
  padding: 80rpx 44rpx 0;
  text-align: center;
  color: #8496b3;
  font-size: 20rpx;
  letter-spacing: 6rpx;
}
