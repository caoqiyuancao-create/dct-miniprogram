.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 90rpx;
}

.review-head {
  padding: 40rpx 44rpx 16rpx;
}

.review-kicker {
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 8rpx;
}

.review-title {
  margin-top: 12rpx;
  font-size: 60rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 2rpx;
}

.review-sub {
  margin-top: 12rpx;
  color: var(--muted);
  font-size: 25rpx;
  line-height: 1.6;
}

.review-list {
  padding: 48rpx 36rpx 0;
  display: flex;
  flex-direction: column;
  gap: 36rpx;
}

.review-card {
  background: #fff;
  border-radius: 36rpx;
  overflow: hidden;
  border: 1rpx solid var(--divider);
  box-shadow: 0 8rpx 28rpx rgba(15,40,85,0.06);
}

.cover {
  height: 360rpx;
  position: relative;
  overflow: hidden;
}

.cover--placeholder {
  background: linear-gradient(135deg, #e7f0fa 0%, #9dbfe3 100%);
}

.cover-img {
  width: 100%;
  height: 100%;
  opacity: 0.88;
  display: block;
}

.cover-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.placeholder-star {
  width: 112rpx;
  height: 112rpx;
  margin-bottom: 16rpx;
  background: rgba(255,255,255,0.7);
  clip-path: polygon(50% 0%, 58% 42%, 100% 50%, 58% 58%, 50% 100%, 42% 58%, 0% 50%, 42% 42%);
}

.placeholder-text {
  color: var(--navy);
  font-size: 26rpx;
  font-weight: 500;
  opacity: 0.7;
}

.vol-badge,
.date-badge {
  position: absolute;
  top: 28rpx;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  letter-spacing: 4rpx;
}

.vol-badge {
  left: 28rpx;
  background: rgba(255,255,255,0.95);
  color: var(--ink);
  font-weight: 600;
  backdrop-filter: blur(20rpx);
}

.date-badge {
  right: 28rpx;
  background: rgba(15,40,85,0.8);
  color: #fff;
  backdrop-filter: blur(20rpx);
}

.review-body {
  padding: 32rpx 36rpx 36rpx;
}

.card-title {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--ink);
  line-height: 1.25;
  letter-spacing: 1rpx;
}

.card-sub {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: var(--muted);
}

.card-speaker {
  margin-top: 24rpx;
  font-size: 23rpx;
  color: var(--muted-soft);
  letter-spacing: 1rpx;
}

.card-summary {
  margin-top: 20rpx;
  color: var(--text-soft);
  font-size: 25rpx;
  line-height: 1.65;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-foot {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.read-more {
  color: #8496b3;
  font-size: 20rpx;
  letter-spacing: 4rpx;
}

.chevron {
  width: 18rpx;
  height: 18rpx;
  border-top: 4rpx solid #8496b3;
  border-right: 4rpx solid #8496b3;
  transform: rotate(45deg);
}

.coming-card {
  background: #fff;
  border-radius: 36rpx;
  padding: 48rpx 40rpx;
  border: 1rpx dashed #c9d4e5;
  text-align: center;
}

.coming-kicker {
  color: #8496b3;
  font-size: 20rpx;
  letter-spacing: 6rpx;
}

.coming-title {
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 32rpx;
  font-weight: 600;
}

.coming-sub {
  margin-top: 8rpx;
  color: #8496b3;
  font-size: 24rpx;
}

.card-hover {
  opacity: 0.86;
  transform: translateY(2rpx);
}
