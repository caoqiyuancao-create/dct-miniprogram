<view class="page">

  <poster-sky tone="deep" min-height="440rpx">
    <view class="hero">
      <view class="mono hero-eyebrow">DCT · 怎么玩</view>
      <view class="serif hero-title">认真玩，认真想</view>
      <view wx:if="{{isV3}}" class="hero-sub">本期搬出客厅，去到「陌生的朋友」咖啡厅 · 一个更轻、更公共的场</view>
    </view>
  </poster-sky>

  <!-- flow -->
  <view class="section">
    <view class="mono section-kicker">活动流程 · 120 – 150 分钟</view>
    <view class="card flow-card">
      <view class="flow-row" wx:for="{{flow}}" wx:key="t" wx:for-item="item">
        <view class="mono flow-time">{{item.t}}</view>
        <view class="flow-label">{{item.l}}</view>
      </view>
    </view>
  </view>

  <!-- event info（数据驱动） -->
  <view class="section">
    <view class="mono section-kicker">时间 · 地点 · 入场</view>
    <view class="card info-card">
      <view class="info-row">
        <view class="mono info-label">时间</view>
        <view class="info-col">
          <view class="info-value">{{dateText}}</view>
          <view class="info-sub">{{timeDetail}}</view>
        </view>
      </view>
      <view class="sep"></view>
      <view class="info-row">
        <view class="mono info-label">地点</view>
        <view class="info-col">
          <view class="info-value">{{location}}</view>
          <view class="info-sub">{{locationNote}}</view>
        </view>
      </view>
      <view class="sep"></view>
      <view class="info-row">
        <view class="mono info-label">入场</view>
        <view class="info-col">
          <view class="info-value">{{price}}</view>
          <view class="info-sub">{{priceNote}}</view>
        </view>
      </view>
      <view wx:if="{{speakerLine}}" class="sep"></view>
      <view wx:if="{{speakerLine}}" class="info-row">
        <view class="mono info-label">主讲</view>
        <view class="info-col">
          <view class="info-value">{{speakerLine}}</view>
          <view wx:if="{{cur.speaker.bio}}" class="info-sub">{{cur.speaker.bio}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- bar rules -->
  <view class="section">
    <view class="mono section-kicker">DCT · 吧规</view>
    <view class="rules-intro">我们认真玩，所以我们也认真设边界。</view>
    <view class="card rules-card">
      <view
        class="rules-row {{item.highlight === 'head' ? 'rules-row--head' : ''}} {{item.highlight === 'wall' ? 'rules-row--wall' : ''}}"
        wx:for="{{rules}}" wx:key="k" wx:for-item="item" wx:for-index="i">
        <view wx:if="{{item.highlight === 'head'}}" class="rule-star">★</view>
        <view wx:else class="mono rule-num">{{i + 1}}</view>
        <view class="rule-body">
          <view class="rule-head">
            <view class="rule-k">{{item.k}}</view>
            <view wx:if="{{item.highlight === 'head'}}" class="mono rule-tag rule-tag--head">HEAD</view>
            <view wx:if="{{item.tag}}" class="mono rule-tag rule-tag--vol">{{item.tag}}</view>
          </view>
          <view class="rule-v">{{item.v}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- entry criteria -->
  <view class="section">
    <view class="mono section-kicker">入场</view>
    <view class="chips">
      <view class="chip" wx:for="{{chips}}" wx:key="*this" wx:for-item="t">{{t}}</view>
    </view>
  </view>

  <view class="cta-wrap">
    <button class="cta" bindtap="goForm" hover-class="cta-hover">
      <text class="cta-text">我已读完 · 去报名</text>
    </button>
  </view>

</view>
