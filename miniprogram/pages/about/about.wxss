.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 80rpx;
}

.story-stage {
  height: 640rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #e7f0fa 0%, #c9ddf3 100%);
}

.stage-rays {
  position: absolute;
  inset: 0;
  opacity: 0.5;
  background: conic-gradient(from 210deg at 50% 110%, rgba(255,255,255,0) 0deg, rgba(255,255,255,0.5) 30deg, rgba(255,255,255,0) 60deg, rgba(255,255,255,0.3) 90deg, rgba(255,255,255,0) 120deg, rgba(255,255,255,0.5) 150deg, rgba(255,255,255,0) 180deg);
}

.about-scene {
  position: absolute;
  inset: 0;
  opacity: 0;
  transform: scale(0.92);
  transition: opacity 0.9s cubic-bezier(0.22,1,0.36,1), transform 0.9s cubic-bezier(0.22,1,0.36,1);
  pointer-events: none;
}

.about-scene.is-active {
  opacity: 1;
  transform: scale(1);
}

.cloud {
  position: absolute;
  height: 44rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.78);
}
.cloud-a { width: 140rpx; left: 150rpx; top: 190rpx; }
.cloud-b { width: 112rpx; right: 150rpx; top: 240rpx; opacity: 0.82; }
.cloud-c { width: 160rpx; left: 300rpx; top: 330rpx; opacity: 0.72; }

.scene-three {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 44rpx;
}

.role-orb {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.74);
  color: var(--navy);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 40rpx rgba(15,40,85,0.14);
  animation: floatY 3s ease-in-out infinite;
}
.role-c { animation-delay: 0.35s; }
.role-t { animation-delay: 0.7s; }
.role-orb text {
  margin-top: 4rpx;
  font-size: 19rpx;
  color: var(--muted);
  font-weight: 500;
}

.field-grid {
  position: absolute;
  left: 150rpx;
  right: 150rpx;
  top: 210rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}
.field-tile {
  height: 86rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.46);
  border: 1rpx solid rgba(15,40,85,0.08);
}
.sprout {
  position: absolute;
  left: 50%;
  top: 250rpx;
  width: 96rpx;
  height: 126rpx;
  transform: translateX(-50%);
}
.sprout-stem {
  position: absolute;
  left: 46rpx;
  bottom: 0;
  width: 6rpx;
  height: 110rpx;
  border-radius: 3rpx;
  background: var(--gold);
}
.sprout-leaf {
  position: absolute;
  width: 54rpx;
  height: 32rpx;
  border-radius: 50% 4rpx 50% 4rpx;
  background: #d7b75e;
}
.sprout-left { left: 0; top: 34rpx; transform: rotate(-28deg); }
.sprout-right { right: 0; top: 18rpx; transform: rotate(28deg) scaleX(-1); }

.scene-brand,
.scene-living,
.scene-invite {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.big-brand {
  font-size: 128rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 8rpx;
}
.brand-sub {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  letter-spacing: 6rpx;
}

.lamp {
  width: 78rpx;
  height: 110rpx;
  border-radius: 36rpx 36rpx 10rpx 10rpx;
  background: rgba(233,185,73,0.34);
  margin-bottom: 18rpx;
  box-shadow: 0 0 60rpx rgba(233,185,73,0.48);
}
.sofa {
  position: relative;
  width: 360rpx;
  height: 150rpx;
}
.sofa-back,
.sofa-seat {
  position: absolute;
  left: 0;
  right: 0;
  border-radius: 36rpx;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid rgba(15,40,85,0.08);
}
.sofa-back { top: 0; height: 96rpx; }
.sofa-seat { bottom: 0; height: 72rpx; }
.pillow {
  position: absolute;
  top: 34rpx;
  width: 78rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: rgba(201,162,74,0.18);
}
.pillow-a { left: 74rpx; }
.pillow-b { right: 74rpx; }

.invite-stars {
  position: absolute;
  width: 320rpx;
  height: 220rpx;
}
.gold-star {
  position: absolute;
  width: 34rpx;
  height: 34rpx;
  background: var(--gold-hi);
  animation: starPulse 2s ease-in-out infinite;
  clip-path: polygon(50% 0%, 58% 42%, 100% 50%, 58% 58%, 50% 100%, 42% 58%, 0% 50%, 42% 42%);
}
.star-0 { left: 30rpx; top: 88rpx; }
.star-1 { right: 40rpx; top: 60rpx; animation-delay: 0.2s; }
.star-2 { left: 120rpx; top: 0; animation-delay: 0.4s; }
.star-3 { right: 104rpx; bottom: 0; animation-delay: 0.6s; }
.star-4 { left: 64rpx; bottom: 26rpx; animation-delay: 0.8s; }
.invite-dct {
  position: relative;
  z-index: 1;
  font-size: 112rpx;
  color: var(--ink);
  font-weight: 900;
  letter-spacing: 10rpx;
}

.scene-caption {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 40rpx;
  text-align: center;
}
.scene-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 0 rgba(255,255,255,0.7);
}
.scene-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 2rpx;
}

.dots {
  position: absolute;
  top: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 8rpx;
}
.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: rgba(26,58,120,0.3);
  transition: width 0.3s;
}
.dot.is-active {
  width: 28rpx;
  background: var(--navy);
}
.replay {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.8);
  color: var(--navy);
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.about-section {
  padding: 56rpx 44rpx 0;
}
.section-kicker {
  font-size: 21rpx;
  color: var(--muted);
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
}
.section-title {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--ink);
  letter-spacing: 2rpx;
  margin-bottom: 28rpx;
}
.body-copy {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.85;
}
.body-copy view {
  margin-bottom: 24rpx;
}
.quote {
  font-size: 30rpx;
  color: var(--navy);
  font-style: italic;
  border-left: 4rpx solid var(--gold);
  padding: 8rpx 0 8rpx 28rpx;
  margin-top: 28rpx;
  line-height: 1.7;
}

.creator-card {
  display: flex;
  gap: 28rpx;
  margin-top: 28rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  border: 1rpx solid var(--divider);
}
.portrait-slot {
  width: 128rpx;
  height: 128rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #e7f0fa 0%, #9dbfe3 100%);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.portrait-letter {
  font-size: 72rpx;
  font-weight: 900;
  color: var(--navy);
  opacity: 0.55;
}
.portrait-tag {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 8rpx;
  text-align: center;
  color: var(--navy);
  font-size: 16rpx;
  opacity: 0.6;
}
.creator-body { flex: 1; min-width: 0; }
.creator-head {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.creator-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink);
}
.creator-word {
  font-size: 20rpx;
  color: var(--muted);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}
.creator-role {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--gold);
  letter-spacing: 2rpx;
}
.creator-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-soft);
  line-height: 1.6;
}
.creator-note {
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-style: italic;
}

.meaning-row {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--divider);
}
.meaning-num {
  width: 48rpx;
  flex-shrink: 0;
  padding-top: 8rpx;
  color: #8496b3;
  font-size: 22rpx;
}
.meaning-body { flex: 1; }
.meaning-en {
  font-size: 28rpx;
  color: var(--navy);
  font-weight: 600;
  line-height: 1.4;
}
.meaning-zh {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 24rpx;
}
.meaning-row--highlight .meaning-num { color: var(--gold); }
.meaning-row--highlight .meaning-en {
  font-size: 34rpx;
  color: var(--ink);
  font-weight: 800;
}
.meaning-row--highlight .meaning-zh { color: var(--warm-ink); }
.after-rows { margin-top: 28rpx; }

.criteria {
  margin: 8rpx 0 24rpx;
  padding-left: 28rpx;
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.85;
}
.criteria view {
  position: relative;
  margin-bottom: 12rpx;
}
.criteria view::before {
  content: '';
  position: absolute;
  left: -24rpx;
  top: 18rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--gold);
}

.closing-card {
  margin: 56rpx 44rpx 0;
  padding: 40rpx 44rpx;
  border-radius: 32rpx;
  border: 1rpx solid #e8dcc0;
  background: linear-gradient(135deg, var(--warm-bg) 0%, var(--warm-bg-2) 100%);
  text-align: center;
}
.closing-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--warm-ink);
  line-height: 1.5;
}
.closing-meta {
  margin-top: 12rpx;
  color: var(--warm-text);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}
.closing-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}
.ghost-btn,
.solid-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0;
}
.ghost-btn {
  border: 1rpx solid var(--gold);
  color: var(--warm-ink);
  background: transparent;
}
.solid-btn {
  border: none;
  color: #fff;
  background: var(--navy);
}
.ghost-btn::after,
.solid-btn::after { border: none; }

@keyframes floatY {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

@keyframes starPulse {
  0%, 100% { transform: scale(1); opacity: 0.72; }
  50% { transform: scale(1.25); opacity: 1; }
}
