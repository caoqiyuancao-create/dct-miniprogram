<view class="page">

  <poster-sky tone="soft">
    <view class="hero">
      <view class="serif hero-title">告诉我们一点你自己</view>
      <view class="hero-sub">
        DCT 希望每期都有多学科的思想碰撞，所以请稍微写多一点——这不是面试，是自我介绍。
      </view>
    </view>
  </poster-sky>

  <view class="body">

    <!-- 基本信息 -->
    <view class="group-label mono">基本信息</view>
    <view class="group-card">
      <view class="field">
        <view class="field-label">姓名</view>
        <input
          class="field-input"
          value="{{form.name}}"
          data-key="name"
          bindinput="onInput"
          placeholder="真实姓名"
          placeholder-class="ph"
        />
      </view>
      <view class="field field-last">
        <view class="field-label">微信号</view>
        <input
          class="field-input mono"
          value="{{form.wechat}}"
          data-key="wechat"
          bindinput="onInput"
          placeholder="用于通知结果与入群"
          placeholder-class="ph"
        />
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="group-label mono">联系方式</view>
    <view class="group-card">
      <view class="field field-last">
        <view class="field-label">手机号</view>
        <input
          class="field-input mono"
          type="number"
          value="{{form.phone}}"
          data-key="phone"
          bindinput="onInput"
          placeholder="+86"
          placeholder-class="ph"
        />
      </view>
    </view>

    <!-- 学术背景 -->
    <view class="group-label mono">学术背景</view>
    <view class="group-card">
      <view class="field">
        <view class="field-label">单位 / 院校</view>
        <input
          class="field-input"
          value="{{form.org}}"
          data-key="org"
          bindinput="onInput"
          placeholder="如：华西医院 / 西南交大"
          placeholder-class="ph"
        />
      </view>
      <view class="field field-last">
        <view class="field-label">专业 / 方向</view>
        <input
          class="field-input"
          value="{{form.field}}"
          data-key="field"
          bindinput="onInput"
          placeholder="如：神经内科、光电工程"
          placeholder-class="ph"
        />
      </view>
    </view>

    <!-- 为什么想参加 -->
    <view class="group-label mono">为什么想参加本期</view>
    <view class="group-card">
      <textarea
        class="textarea"
        value="{{form.why}}"
        data-key="why"
        bindinput="onInput"
        placeholder="可以聊聊：你对『目标管理 / 坚持哲学 / 长期主义』的思考，或者你与马拉松、与研究生涯的故事……"
        placeholder-class="ph"
        maxlength="-1"
        auto-height
      />
    </view>

    <!-- consent -->
    <view class="consent" bindtap="toggleAgree">
      <view class="checkbox {{agreed ? 'checkbox-on' : ''}}">
        <view wx:if="{{agreed}}" class="check"></view>
      </view>
      <view class="consent-text">
        我已阅读并同意 <text class="consent-link">DCT · 吧规</text>：保密 · 尊重 · 不贴标签 · 非治疗场合 · 轮流发言 · 友好纠错。
      </view>
    </view>

    <view class="submit-wrap">
      <button
        class="submit {{submitting ? 'submit-disabled' : ''}}"
        bindtap="submit"
        hover-class="submit-hover"
        disabled="{{submitting}}"
      >{{submitting ? '提交中…' : '提交报名'}}</button>
      <view class="submit-sub">我们会在 24 小时内通过微信回复你</view>
    </view>
  </view>
</view>
