.page {
  background: #f6f8fc;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.hero {
  padding: 40rpx 44rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.constellation {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  margin-top: 20rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 60rpx;
  font-weight: 900;
  color: #0f2855;
  letter-spacing: 6rpx;
  margin-top: 16rpx;
}
.hero-sub {
  font-size: 26rpx;
  color: #3d5f94;
  margin-top: 16rpx;
  text-align: center;
  line-height: 1.7;
  max-width: 560rpx;
}

.section {
  padding: 44rpx 44rpx 0;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  border: 1rpx solid #e3e9f3;
}
.timeline {
  padding: 12rpx 0;
}

.step {
  display: flex;
  gap: 28rpx;
  padding: 28rpx 36rpx;
  position: relative;
}
.step-rail {
  width: 44rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 14rpx;
  background: #c9d4e6;
  display: flex;
  align-items: center;
  justify-content: center;
}
.dot-done   { background: #2c5ca0; }
.dot-active {
  background: #e9b949;
  box-shadow: 0 0 0 8rpx rgba(233,185,73,0.22);
}
.dot-check {
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(-45deg);
  margin-top: -2rpx;
}
.line {
  width: 2rpx;
  flex: 1;
  background: #e3e9f3;
  margin-top: 8rpx;
  min-height: 24rpx;
}
.step-body { flex: 1; padding-bottom: 8rpx; }
.step-body-done .step-label   { color: #0f2855; font-weight: 600; }
.step-body-active .step-label { color: #8a6715; font-weight: 600; }
.step-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #6b7a91;
}
.step-sub {
  font-size: 23rpx;
  color: #8496b3;
  margin-top: 4rpx;
}

/* notice */
.notice {
  background: rgba(233,185,73,0.1);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid rgba(201,162,74,0.3);
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}
.notice-bullet {
  width: 24rpx;
  height: 24rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  background: #c9a24a;
  clip-path: polygon(
    50% 0%, 58% 42%, 100% 50%, 58% 58%,
    50% 100%, 42% 58%, 0% 50%, 42% 42%
  );
}
.notice-text {
  font-size: 25rpx;
  color: #6b5520;
  line-height: 1.65;
  flex: 1;
}

/* back btn */
.cta-wrap {
  padding: 48rpx 36rpx 60rpx;
}
.back-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  background: #fff;
  color: #1a3a78;
  border: 1rpx solid #c9d4e6;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}
.back-btn::after { border: none; }
.back-hover { background: #f4f7fc; }
