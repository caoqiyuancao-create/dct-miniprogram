page {
  height: 100vh;
  background: #050d1d;
  overflow: hidden;
}

.serif { font-family: "Songti SC", "STSong", "Noto Serif SC", serif; }
.mono  { font-family: "SF Mono", "JetBrains Mono", "Menlo", ui-monospace, monospace; }

.wall {
  width: 100vw;
  height: 100vh;
  color: #fff;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(ellipse at top right, #1d3d6b 0%, #0c1f3d 50%, #050d1d 100%);
}

.watermark {
  position: absolute;
  right: -40rpx;
  bottom: -120rpx;
  font-size: 560rpx;
  font-weight: 900;
  color: rgba(255,255,255,0.03);
  letter-spacing: 16rpx;
  line-height: 1;
  pointer-events: none;
  z-index: 1;
}

.star-deco {
  position: absolute;
  background: #e9b949;
  clip-path: polygon(50% 0%,58% 42%,100% 50%,58% 58%,50% 100%,42% 58%,0% 50%,42% 42%);
  z-index: 1;
}
.star-deco--1 { right: 8%; top: 12%; width: 28rpx; height: 28rpx; opacity: 0.55; }
.star-deco--2 { left: 5%;  top: 20%; width: 20rpx; height: 20rpx; opacity: 0.4; }
.star-deco--3 { right: 6%; top: 62%; width: 18rpx; height: 18rpx; opacity: 0.35; }
.star-deco--4 { left: 3%;  top: 86%; width: 24rpx; height: 24rpx; opacity: 0.4; }

.header {
  padding: 36rpx 80rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 36rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
  position: relative;
  z-index: 2;
}
.header__logo {
  width: 96rpx; height: 96rpx; border-radius: 48rpx;
  background: #fff;
  padding: 6rpx;
  box-sizing: border-box;
  box-shadow: 0 0 0 3rpx rgba(255,255,255,0.4);
}
.header__center { flex: 1; }
.header__kicker {
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: #e9b949;
  margin-bottom: 8rpx;
}
.header__title {
  font-size: 56rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 4rpx;
  line-height: 1.15;
}
.header__title-gold { color: #e9b949; }

.header__right { text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.header__clock {
  font-size: 64rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
  color: #fff;
  font-variant-numeric: tabular-nums;
}
.header__clock-gold { color: #e9b949; }
.header__date {
  font-size: 20rpx;
  color: rgba(255,255,255,0.55);
  letter-spacing: 3rpx;
}

.cols {
  display: flex;
  padding: 36rpx 64rpx 100rpx;
  gap: 48rpx;
  height: calc(100vh - 240rpx);
  position: relative;
  z-index: 2;
  box-sizing: border-box;
}
.col { flex: 1; min-width: 0; overflow: hidden; }
.cols__divider {
  width: 2rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.18) 30%, rgba(255,255,255,0.18) 70%, transparent 100%);
}

.col__kicker {
  font-size: 22rpx;
  letter-spacing: 6rpx;
  margin-bottom: 14rpx;
  font-weight: 500;
}
.col__kicker--blue { color: #9ac4ff; }
.col__kicker--gold { color: #e9b949; }
.col__title {
  font-size: 50rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  line-height: 1.15;
}
.col__sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}

.intros {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.intro-card {
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.10);
  border-radius: 20rpx;
  padding: 22rpx 28rpx;
  display: flex;
  gap: 24rpx;
  align-items: center;
  animation: wallEnter 0.6s ease forwards;
}
.intro-card__avatar {
  width: 64rpx; height: 64rpx; border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(154,196,255,0.2) 0%, rgba(154,196,255,0.05) 100%);
  border: 1rpx solid rgba(154,196,255,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 700; color: #bfd8ff;
  font-family: "SF Mono", "JetBrains Mono", monospace;
  flex-shrink: 0;
}
.intro-card__body { flex: 1; min-width: 0; }
.intro-card__who {
  font-size: 20rpx;
  color: #9ac4ff;
  letter-spacing: 1.5rpx;
  margin-bottom: 6rpx;
}
.intro-card__line {
  font-size: 30rpx;
  color: #fff;
  line-height: 1.4;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.questions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 36rpx;
}
.q-card {
  position: relative;
  padding: 14rpx 0 32rpx 56rpx;
  border-bottom: 1rpx solid rgba(233,185,73,0.18);
  animation: wallEnter 0.65s ease forwards;
}
.q-card__quote {
  position: absolute;
  left: -8rpx; top: -12rpx;
  font-size: 80rpx;
  color: rgba(233,185,73,0.6);
  line-height: 1;
  font-weight: 700;
}
.q-card__num {
  font-size: 20rpx;
  color: #e9b949;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
  font-weight: 500;
}
.q-card__text {
  font-size: 34rpx;
  color: #fff;
  line-height: 1.45;
  letter-spacing: 0.6rpx;
}

.footer {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 24rpx 80rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.3) 100%);
  display: flex; align-items: center; justify-content: space-between;
  border-top: 1rpx solid rgba(255,255,255,0.06);
  z-index: 3;
}
.footer__brand {
  font-size: 20rpx;
  color: rgba(255,255,255,0.55);
  letter-spacing: 4rpx;
}
.footer__live {
  display: flex; align-items: center; gap: 14rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}
.footer__live-dot {
  width: 14rpx; height: 14rpx; border-radius: 7rpx;
  background: #5fd97b;
  box-shadow: 0 0 16rpx #5fd97b;
  animation: wallPulse 1.6s ease-in-out infinite;
}

@keyframes wallPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.4; transform: scale(0.8); }
}
@keyframes wallEnter {
  from { opacity: 0; transform: translateY(28rpx); }
  to   { opacity: var(--wall-final-opacity, 1); transform: translateY(0); }
}
