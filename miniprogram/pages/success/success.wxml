<view class="page">

  <poster-sky tone="light" min-height="720rpx">
    <view class="hero">
      <view class="constellation">
        <star-4
          wx:for="{{constellation}}"
          wx:key="s"
          x="{{item.x}}"
          y="{{item.y}}"
          s="{{item.s}}"
          o="{{item.o}}"
        />
      </view>
      <view class="serif hero-title">已收到</view>
      <view class="hero-sub">
        <view>谢谢你愿意和我们一起</view>
        <view>{{isV3 ? '在“变得更好”的喧闹之外，留一点冷思考。' : '在绩效逻辑之外，聊点真的东西'}}</view>
      </view>
    </view>
  </poster-sky>

  <!-- v3 · 留言墙预告卡 -->
  <view wx:if="{{isV3}}" class="section">
    <view class="wall-card" bindtap="goWall" hover-class="wall-card-hover">
      <view class="wall-card__deco"></view>
      <view class="mono wall-card__kicker">WALL · 当晚电视上滚动展示</view>
      <view class="serif wall-card__title">你写下的，会被看到。</view>
      <view class="wall-card__body">你留下的一句话身份和想问的问题，会在入场和中场以匿名形式在咖啡厅 TV 上滚动播放。</view>
      <view class="wall-card__btn">
        <text>看看现场留言墙长什么样</text>
        <view class="wall-card__chev"></view>
      </view>
    </view>
  </view>

  <!-- timeline -->
  <view class="section">
    <view class="card timeline">
      <view class="step" wx:for="{{steps}}" wx:key="label" wx:for-item="step" wx:for-index="i">
        <view class="step-rail">
          <view class="dot dot-{{step.state}}">
            <view wx:if="{{step.state === 'done'}}" class="dot-check"></view>
          </view>
          <view wx:if="{{!step.last}}" class="line"></view>
        </view>
        <view class="step-body step-body-{{step.state}}">
          <view class="step-label">{{step.label}}</view>
          <view class="step-sub">{{step.sub}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="notice">
      <view class="notice-bullet"></view>
      <view class="notice-text">
        DCT 会综合学科背景与交流意愿筛选本期参与者。若本期暂未入选，我们会优先邀请你参加下一期同类主题。
      </view>
    </view>
  </view>

  <view class="section">
    <button class="cal-btn" bindtap="addToCalendar" hover-class="cal-btn-hover" aria-label="加入手机日历">
      <view class="cal-icon"></view>
      <text>加入手机日历</text>
    </button>
  </view>

  <view class="section">
    <button class="ticket-btn" bindtap="generateTicket" hover-class="ticket-hover" aria-label="生成邀请券海报">
      <view class="ticket-icon"></view>
      <text>生成邀请券</text>
    </button>
    <view class="ticket-sub">为这一夜留个纪念 · 保存到相册</view>
  </view>

  <view class="cta-wrap">
    <button class="back-btn" bindtap="backToLanding" hover-class="back-hover">回到主题介绍</button>
  </view>

  <canvas
    canvas-id="ticketCanvas"
    class="ticket-canvas"
    style="width: 750rpx; height: 1334rpx;"></canvas>
</view>
