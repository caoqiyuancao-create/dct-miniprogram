.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 80rpx;
}

.cover {
  height: 480rpx;
  position: relative;
  overflow: hidden;
}

.cover--placeholder {
  background: linear-gradient(135deg, #e7f0fa 0%, #9dbfe3 100%);
}

.cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.cover-star {
  position: absolute;
  left: 50%;
  top: 45%;
  width: 160rpx;
  height: 160rpx;
  transform: translate(-50%, -50%);
  background: rgba(255,255,255,0.7);
  clip-path: polygon(50% 0%, 58% 42%, 100% 50%, 58% 58%, 50% 100%, 42% 58%, 0% 50%, 42% 42%);
}

.cover-shade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 260rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(15,40,85,0.85) 100%);
}

.cover-copy {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 120rpx 44rpx 36rpx;
  color: #fff;
}

.cover-kicker {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  opacity: 0.8;
}

.cover-title {
  margin-top: 8rpx;
  font-size: 56rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.cover-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.85;
}

.section {
  padding: 44rpx 44rpx 0;
}

.speaker-card,
.photos-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid var(--divider);
}

.card-kicker,
.section-kicker,
.photos-kicker {
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: #8496b3;
}

.speaker-name {
  margin-top: 8rpx;
  color: var(--ink);
  font-size: 34rpx;
  font-weight: 700;
}

.speaker-title {
  margin-left: 12rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 400;
}

.speaker-org {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 24rpx;
}

.section-kicker {
  color: var(--muted);
}

.section-title {
  margin-top: 8rpx;
  margin-bottom: 20rpx;
  color: var(--ink);
  font-size: 34rpx;
  font-weight: 700;
}

.summary {
  color: var(--text);
  font-size: 26rpx;
  line-height: 1.85;
}

.quote-card {
  margin-bottom: 20rpx;
  padding: 24rpx 28rpx;
  border-left: 4rpx solid var(--gold);
  border-radius: 0 24rpx 24rpx 0;
  background: linear-gradient(180deg, rgba(233,185,73,0.08) 0%, rgba(233,185,73,0.02) 100%);
}

.quote-text {
  color: var(--navy);
  font-size: 28rpx;
  line-height: 1.7;
  font-style: italic;
}

.quote-author {
  margin-top: 12rpx;
  color: var(--muted-soft);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.photos-card {
  border-style: dashed;
  border-color: #c9d4e5;
  text-align: center;
  padding: 40rpx 36rpx;
}

.photos-text {
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 26rpx;
}

.bottom-action {
  padding: 64rpx 44rpx 0;
}

.back-btn {
  width: 100%;
  height: 84rpx;
  border-radius: 42rpx;
  background: transparent;
  border: 1rpx solid #c9d4e5;
  color: var(--navy);
  font-size: 26rpx;
  font-weight: 500;
}

.back-btn::after { border: none; }
.back-hover { background: rgba(255,255,255,0.7); }
