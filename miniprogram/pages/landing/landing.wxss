.page {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 220rpx; /* 留出 sticky CTA 高度 */
}

/* ======================================================
   CHG-02 U1 · 顶部金色滚动进度条
====================================================== */
.scroll-progress {
  position: sticky;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  z-index: 100;
  pointer-events: none;
  background: transparent;
}
.scroll-progress__fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gold) 0%, var(--gold-hi) 100%);
  box-shadow: 0 0 12rpx var(--gold-hi);
  transition: width 0.05s linear;
}

/* ================ HERO ================ */
.hero {
  display: flex;
  gap: 16rpx;
  padding: 28rpx 44rpx 0;
  position: relative;
}
.hero-left { flex: 1; min-width: 0; }
.hero-meta-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}
.eyebrow {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: var(--navy);
  opacity: 0.85;
}

/* CHG-03 F5 · 倒计时 chip */
.countdown-chip {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: rgba(201,162,74,0.15);
  color: var(--gold);
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.title {
  font-size: 104rpx;
  font-weight: 900;
  line-height: 1.02;
  color: var(--ink);
  letter-spacing: 4rpx;
  text-shadow: 0 1rpx 0 rgba(255,255,255,0.6);
}
.subline {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: var(--navy);
  font-size: 26rpx;
  font-weight: 500;
}
.subline-dash {
  margin-top: 12rpx;
  color: var(--text-soft);
  font-size: 23rpx;
  letter-spacing: 0.6rpx;
}

/* CHG-02 U3 · Hero portrait 240rpx (was 276rpx) */
.hero-portrait-wrap {
  width: 240rpx;
  flex-shrink: 0;
  margin-top: -8rpx;
  margin-right: -20rpx;
  position: relative;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 48rpx rgba(15,40,85,0.22), 0 0 0 6rpx rgba(255,255,255,0.9);
  aspect-ratio: 7 / 10;
}
.hero-portrait { width: 100%; height: 100%; display: block; }
.hero-portrait-fade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(231,240,250,0) 55%, rgba(15,40,85,0.18) 100%);
  pointer-events: none;
}

/* ======================================================
   CHG-03 F1 · 报名状态横幅
====================================================== */
.reg-banner {
  margin: 32rpx 36rpx 0;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(90deg, var(--warm-bg) 0%, var(--warm-bg-2) 100%);
  border: 1rpx solid rgba(107,76,30,0.16);
  box-shadow: 0 8rpx 24rpx rgba(107,76,30,0.08);
}
.reg-banner__dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(255,255,255,0.6);
}
.reg-banner--pending  .reg-banner__dot { background: #c9a24a; }
.reg-banner--approved .reg-banner__dot { background: #3d8b5e; }
.reg-banner--rejected .reg-banner__dot { background: #c25450; }
.reg-banner__text {
  font-size: 26rpx;
  color: var(--warm-ink);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* ================ SPEAKER CARD ================ */
.speaker-wrap { padding: 64rpx 36rpx 0; }
.speaker-card {
  background: rgba(255,255,255,0.78);
  backdrop-filter: blur(18rpx) saturate(160%);
  -webkit-backdrop-filter: blur(18rpx) saturate(160%);
  border: 1rpx solid rgba(15,40,85,0.12);
  border-radius: 36rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(20,50,100,0.1);
}
.speaker-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  flex-shrink: 0;
  overflow: hidden;
  background: #e4edf7;
  border: 3rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 4rpx 16rpx rgba(15,40,85,0.15);
}
.speaker-avatar-img { width: 100%; height: 100%; display: block; }
.speaker-info { flex: 1; min-width: 0; }
.speaker-name { font-size: 30rpx; font-weight: 600; color: var(--ink); }
.speaker-title { font-size: 24rpx; font-weight: 400; color: var(--muted); }
.speaker-bio {
  font-size: 23rpx;
  color: var(--muted);
  margin-top: 6rpx;
  line-height: 1.45;
}

/* ================ SECTIONS ================ */
.section { padding: 44rpx 44rpx 0; }
.section-top { padding-top: 52rpx; }
.section-kicker {
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 6rpx;
  margin-bottom: 8rpx;
  text-transform: uppercase;
}
.section-title {
  font-size: 36rpx;
  color: var(--ink);
  font-weight: 700;
  margin-bottom: 28rpx;
}

/* ================ OPENING ================ */
.opening-title {
  font-size: 38rpx;
  font-weight: 500;
  color: var(--ink);
  line-height: 1.65;
  letter-spacing: 1rpx;
}
.opening-body {
  font-size: 26rpx;
  color: var(--text-soft);
  margin-top: 28rpx;
  line-height: 1.8;
}
.opening-accent { color: var(--ink); font-weight: 500; }

/* ======================================================
   CHG-02 U4 · POINT CARDS（图标 + 编号移到标题右侧）
====================================================== */
.points {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.point-card {
  background: var(--card);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid var(--divider);
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}
.point-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: rgba(201,162,74,0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.ico { width: 40rpx; height: 40rpx; position: relative; }

/* lanes — 三条横线，每条末端一个金点 */
.ico-lanes {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}
.ico-lane {
  height: 2rpx;
  background: var(--gold);
  position: relative;
  border-radius: 1rpx;
}
.ico-lane:nth-child(1) { width: 100%; }
.ico-lane:nth-child(2) { width: 70%; }
.ico-lane:nth-child(3) { width: 85%; }
.ico-dot {
  width: 8rpx; height: 8rpx; border-radius: 50%;
  background: var(--gold);
  position: absolute; right: -4rpx; top: 50%;
  transform: translateY(-50%);
}

/* footprint — 两组脚印（左右交替） */
.ico-footprint { /* container only */ }
.ico-foot {
  position: absolute;
  width: 12rpx; height: 16rpx;
  border-radius: 50% 50% 40% 40%;
  background: var(--gold);
}
.ico-foot--l1 { left: 4rpx;  top: 4rpx;  }
.ico-foot--r1 { left: 22rpx; top: 10rpx; }
.ico-foot--l2 { left: 6rpx;  top: 22rpx; }
.ico-foot--r2 { left: 24rpx; top: 26rpx; }

/* compass — 圆 + 内嵌指针 */
.ico-compass {
  border: 2rpx solid var(--gold);
  border-radius: 50%;
}
.ico-compass-needle {
  position: absolute;
  left: 50%; top: 50%;
  width: 4rpx; height: 26rpx;
  background: linear-gradient(180deg, var(--gold) 0%, var(--gold) 50%, transparent 50%, transparent 100%);
  transform: translate(-50%, -50%) rotate(35deg);
  border-radius: 2rpx;
}

.point-body { flex: 1; min-width: 0; }
.point-head {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.point-num {
  font-size: 20rpx;
  color: var(--gold);
  font-weight: 600;
  letter-spacing: 2rpx;
  flex-shrink: 0;
}
.point-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.3;
  flex: 1;
  min-width: 0;
}
.point-sub {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 4rpx;
}
.point-text {
  font-size: 25rpx;
  color: var(--text-soft);
  margin-top: 16rpx;
  line-height: 1.65;
}

/* ================ CLOSING PULL QUOTE ================ */
.closing {
  background: linear-gradient(180deg, rgba(233,185,73,0.08) 0%, rgba(233,185,73,0.02) 100%);
  border-left: 4rpx solid var(--gold);
  padding: 28rpx 32rpx;
  border-radius: 0 24rpx 24rpx 0;
}
.closing-text {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.75;
}
.closing-accent { color: var(--ink); font-weight: 600; }

/* ======================================================
   CHG-02 U7 · INFO CARD — 用 ::after 实现行间分隔
====================================================== */
.info-card {
  background: var(--card);
  border-radius: 32rpx;
  padding: 32rpx 36rpx;
  border: 1rpx solid var(--divider);
}
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  padding: 18rpx 0;
  position: relative;
}
.info-row:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 1rpx;
  background: #e9eef6;
}
.info-label {
  font-size: 22rpx;
  color: #8496b3;
  letter-spacing: 4rpx;
  width: 68rpx;
  padding-top: 6rpx;
  flex-shrink: 0;
}
.info-col { flex: 1; }
.info-value {
  font-size: 29rpx;
  color: var(--ink);
  font-weight: 500;
}
.info-sub {
  font-size: 23rpx;
  color: var(--muted-soft);
  margin-top: 4rpx;
}

/* ================ MENU CARD ================ */
.menu-card {
  background: linear-gradient(135deg, var(--warm-bg) 0%, var(--warm-bg-2) 100%);
  border-radius: 32rpx;
  padding: 32rpx 36rpx;
  border: 1rpx solid #e8dcc0;
}
.menu-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--warm-ink);
  line-height: 1.35;
}
.menu-sub {
  font-size: 24rpx;
  color: var(--warm-text);
  margin-top: 8rpx;
  font-style: italic;
}

/* CHG-02 U5 · 不含正餐 chip */
.menu-chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-radius: 200rpx;
  background: rgba(107,76,30,0.08);
  border: 1rpx solid rgba(107,76,30,0.18);
  font-size: 23rpx;
  color: var(--warm-ink);
  margin-top: 24rpx;
}
.menu-chip__icon {
  width: 22rpx; height: 22rpx;
  border: 2rpx solid var(--warm-ink);
  border-radius: 50%;
  position: relative;
}
.menu-chip__icon::after {
  content: '';
  position: absolute;
  left: -4rpx; right: -4rpx;
  top: 50%;
  height: 2rpx;
  background: var(--warm-ink);
  transform: translateY(-50%) rotate(-45deg);
}

.menu-sep {
  height: 1rpx;
  background: #e0d2b0;
  margin: 24rpx 0;
}
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.menu-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.menu-name {
  font-size: 29rpx;
  color: #5a3f14;
  font-weight: 600;
  flex: 1;
}
.menu-tag {
  font-size: 21rpx;
  color: var(--warm-text);
  letter-spacing: 2rpx;
}
.menu-foot {
  font-size: 23rpx;
  color: var(--warm-text);
  margin-top: 24rpx;
  line-height: 1.55;
  font-style: italic;
}

/* ================ WHAT IS DCT ================ */
.dct-head {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}
.dct-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  flex-shrink: 0;
}
.dct-head-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.25;
  margin-top: 4rpx;
}
.dct-tagline {
  font-size: 25rpx;
  color: var(--text-soft);
  font-style: italic;
  line-height: 1.65;
}
.dct-latin {
  font-size: 23rpx;
  color: var(--muted-soft);
  margin-top: 12rpx;
  letter-spacing: 0.6rpx;
}
.dct-body {
  font-size: 26rpx;
  color: var(--text);
  margin-top: 28rpx;
  line-height: 1.75;
}
.dct-body-line2 { margin-top: 4rpx; }
.dct-invite {
  font-size: 28rpx;
  color: var(--navy);
  margin-top: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ================ RULES ENTRY ================ */
.rules-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: var(--card);
  border-radius: 28rpx;
  border: 1rpx solid var(--divider);
}
.rules-entry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
}
.rules-entry-sub {
  font-size: 23rpx;
  color: var(--muted-soft);
  margin-top: 4rpx;
}
.chevron {
  width: 18rpx;
  height: 18rpx;
  border-right: 4rpx solid #a0acc0;
  border-top: 4rpx solid #a0acc0;
  transform: rotate(45deg);
}

/* ================ CTA ================ */
.cta-wrap { padding: 48rpx 36rpx 60rpx; }
.cta {
  width: 100%;
  height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(180deg, var(--navy-soft) 0%, var(--navy) 100%);
  color: #fff;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
  box-shadow: 0 16rpx 44rpx rgba(26,58,120,0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 0;
}
.cta::after { border: none; }
.cta-hover {
  opacity: 0.92;
  transform: scale(0.99);
}
.cta-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
}
.cta-sub {
  margin-top: 20rpx;
  text-align: center;
  font-size: 23rpx;
  color: var(--muted-soft);
}
.cta-sub-accent { color: var(--navy-soft); }

.tap-hover { background: #f4f7fc; }

/* ======================================================
   CHG-02 U2 · 吸底浮动 CTA（用 fixed，per pasted note）
====================================================== */
.sticky-cta {
  position: fixed;
  bottom: 36rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 80;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(40rpx) saturate(180%);
  -webkit-backdrop-filter: blur(40rpx) saturate(180%);
  border: 1rpx solid var(--divider);
  border-radius: 60rpx;
  box-shadow: 0 24rpx 60rpx rgba(15,40,85,0.18);
  padding: 16rpx 16rpx 16rpx 36rpx;
  opacity: 0;
  transform: translateY(40rpx);
  pointer-events: none;
  transition: opacity 280ms cubic-bezier(0.22, 1, 0.36, 1),
              transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
}
.sticky-cta.is-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}
.sticky-cta__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.sticky-cta__info {
  flex: 1;
  min-width: 0;
}
.sticky-cta__kicker {
  font-size: 20rpx;
  color: var(--muted);
  letter-spacing: 4rpx;
}
.sticky-cta__price {
  margin-top: 4rpx;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  color: var(--ink);
}
.sticky-cta__num {
  font-size: 36rpx;
  font-weight: 700;
}
.sticky-cta__unit {
  font-size: 22rpx;
  color: var(--muted);
}
.sticky-cta__hint {
  font-size: 20rpx;
  color: var(--muted-soft);
  margin-left: 4rpx;
}
.sticky-cta__btn {
  height: 88rpx;
  padding: 0 36rpx;
  border-radius: 44rpx;
  background: linear-gradient(180deg, var(--navy-soft) 0%, var(--navy) 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}
.sticky-cta__star { width: 20rpx; height: 20rpx; }

/* ================ STAR BULLET (inline) ================ */
.star-bullet {
  width: 20rpx;
  height: 20rpx;
  flex-shrink: 0;
  clip-path: polygon(
    50% 0%, 58% 42%, 100% 50%, 58% 58%,
    50% 100%, 42% 58%, 0% 50%, 42% 42%
  );
}
.star-gold  { background: var(--gold); }
.star-brown { background: #b8903a; width: 18rpx; height: 18rpx; }
.star-cta   { background: var(--gold-hi); width: 24rpx; height: 24rpx; }
