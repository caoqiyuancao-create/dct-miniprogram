.page {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.hero {
  padding: 36rpx 44rpx 56rpx;
}
.hero-eyebrow {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: rgba(255,255,255,0.88);
  margin-bottom: 16rpx;
}
.hero-title {
  font-size: 64rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(10,30,60,0.3);
}

.section {
  padding: 44rpx 44rpx 0;
}
.section-kicker {
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 6rpx;
  text-transform: uppercase;
  margin-bottom: 20rpx;
}

.card {
  background: var(--card);
  border-radius: 32rpx;
  border: 1rpx solid var(--divider);
}

.flow-card {
  padding: 16rpx 0;
}
.flow-row {
  display: flex;
  gap: 32rpx;
  padding: 24rpx 36rpx;
  align-items: center;
  border-bottom: 1rpx solid var(--divider-soft);
}
.flow-row:last-child { border-bottom: none; }
.flow-time {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--navy-soft);
  width: 92rpx;
  flex-shrink: 0;
}
.flow-label {
  font-size: 28rpx;
  color: var(--ink);
}

/* info card */
.info-card {
  padding: 32rpx 36rpx;
}
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  padding: 8rpx 0;
}
.info-label {
  font-size: 22rpx;
  color: var(--text-hint);
  letter-spacing: 4rpx;
  width: 68rpx;
  padding-top: 6rpx;
  flex-shrink: 0;
}
.info-col { flex: 1; }
.info-value {
  font-size: 29rpx;
  color: var(--ink);
  font-weight: 500;
}
.info-sub {
  font-size: 23rpx;
  color: var(--muted-soft);
  margin-top: 4rpx;
}
.sep {
  height: 1rpx;
  background: #e9eef6;
  margin: 20rpx 0;
}

/* rules */
.rules-intro {
  font-size: 25rpx;
  color: var(--text-soft);
  margin-top: 12rpx;
  margin-bottom: 20rpx;
  font-style: italic;
}
.rules-card {
  padding: 8rpx 0;
}
.rules-row {
  display: flex;
  gap: 28rpx;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid var(--divider-soft);
  align-items: flex-start;
}
.rules-row:last-child { border-bottom: none; }
.rule-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #eaf0f9;
  color: var(--navy-soft);
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.rule-body { flex: 1; }
.rule-k {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
}
.rule-v {
  font-size: 25rpx;
  color: var(--muted);
  margin-top: 4rpx;
  line-height: 1.6;
}

/* chips */
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}
.chip {
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: var(--card);
  color: var(--navy-soft);
  border: 1rpx solid var(--chip-border);
}

/* cta */
.cta-wrap {
  padding: 48rpx 36rpx 60rpx;
}
.cta {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(180deg, var(--navy-soft) 0%, var(--navy) 100%);
  color: #fff;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  box-shadow: 0 16rpx 44rpx rgba(26,58,120,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}
.cta::after { border: none; }
.cta-hover { opacity: 0.92; }
.cta-text { color: #fff; }
