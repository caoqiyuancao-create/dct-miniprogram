.page {
  background: #f6f8fc;
  min-height: 100vh;
  padding-bottom: 80rpx;
}

/* ================ HERO ================ */
.hero {
  display: flex;
  gap: 16rpx;
  padding: 28rpx 44rpx 0;
  position: relative;
}
.hero-left {
  flex: 1;
  min-width: 0;
}
.eyebrow {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: #1a3a78;
  opacity: 0.85;
  margin-bottom: 20rpx;
}
.title {
  font-size: 104rpx;
  font-weight: 900;
  line-height: 1.02;
  color: #0f2855;
  letter-spacing: 4rpx;
  text-shadow: 0 1rpx 0 rgba(255,255,255,0.6);
}
.subline {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #1a3a78;
  font-size: 26rpx;
  font-weight: 500;
}
.subline-dash {
  margin-top: 12rpx;
  color: #3d5f94;
  font-size: 23rpx;
  letter-spacing: 0.6rpx;
}

.hero-portrait-wrap {
  width: 276rpx;
  flex-shrink: 0;
  margin-top: -8rpx;
  margin-right: -20rpx;
  position: relative;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 48rpx rgba(15,40,85,0.22), 0 0 0 6rpx rgba(255,255,255,0.9);
  aspect-ratio: 7 / 10;
}
.hero-portrait {
  width: 100%;
  height: 100%;
  display: block;
}
.hero-portrait-fade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(231,240,250,0) 55%, rgba(15,40,85,0.18) 100%);
  pointer-events: none;
}

/* ================ SPEAKER CARD ================ */
.speaker-wrap {
  padding: 80rpx 36rpx 0;
}
.speaker-card {
  background: rgba(255,255,255,0.78);
  backdrop-filter: blur(18rpx) saturate(160%);
  -webkit-backdrop-filter: blur(18rpx) saturate(160%);
  border: 1rpx solid rgba(15,40,85,0.12);
  border-radius: 36rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(20,50,100,0.1);
}
.speaker-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  flex-shrink: 0;
  overflow: hidden;
  background: #e4edf7;
  border: 3rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 4rpx 16rpx rgba(15,40,85,0.15);
}
.speaker-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}
.speaker-info {
  flex: 1;
  min-width: 0;
}
.speaker-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f2855;
}
.speaker-title {
  font-size: 24rpx;
  font-weight: 400;
  color: #55709a;
}
.speaker-bio {
  font-size: 23rpx;
  color: #55709a;
  margin-top: 6rpx;
  line-height: 1.45;
}

/* ================ SECTIONS ================ */
.section {
  padding: 44rpx 44rpx 0;
}
.section-top {
  padding-top: 52rpx;
}
.section-kicker {
  font-size: 22rpx;
  color: #55709a;
  letter-spacing: 6rpx;
  margin-bottom: 8rpx;
  text-transform: uppercase;
}
.section-title {
  font-size: 36rpx;
  color: #0f2855;
  font-weight: 700;
  margin-bottom: 28rpx;
}

/* ================ OPENING ================ */
.opening-title {
  font-size: 38rpx;
  font-weight: 500;
  color: #0f2855;
  line-height: 1.65;
  letter-spacing: 1rpx;
}
.opening-body {
  font-size: 26rpx;
  color: #3d5f94;
  margin-top: 28rpx;
  line-height: 1.8;
}
.opening-accent {
  color: #0f2855;
  font-weight: 500;
}

/* ================ POINT CARDS ================ */
.points {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.point-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid #e3e9f3;
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}
.point-num {
  font-size: 24rpx;
  color: #c9a24a;
  font-weight: 600;
  padding-top: 4rpx;
  letter-spacing: 2rpx;
  flex-shrink: 0;
}
.point-body {
  flex: 1;
  min-width: 0;
}
.point-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f2855;
  line-height: 1.3;
}
.point-sub {
  font-size: 24rpx;
  color: #55709a;
  margin-top: 4rpx;
}
.point-text {
  font-size: 25rpx;
  color: #3d5f94;
  margin-top: 16rpx;
  line-height: 1.65;
}

/* ================ CLOSING PULL QUOTE ================ */
.closing {
  background: linear-gradient(180deg, rgba(233,185,73,0.08) 0%, rgba(233,185,73,0.02) 100%);
  border-left: 4rpx solid #c9a24a;
  padding: 28rpx 32rpx;
  border-radius: 0 24rpx 24rpx 0;
}
.closing-text {
  font-size: 26rpx;
  color: #2a3d5c;
  line-height: 1.75;
}
.closing-accent {
  color: #0f2855;
  font-weight: 600;
}

/* ================ INFO CARD ================ */
.info-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx 36rpx;
  border: 1rpx solid #e3e9f3;
}
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  padding: 8rpx 0;
}
.info-label {
  font-size: 22rpx;
  color: #8496b3;
  letter-spacing: 4rpx;
  width: 68rpx;
  padding-top: 6rpx;
  flex-shrink: 0;
}
.info-col { flex: 1; }
.info-value {
  font-size: 29rpx;
  color: #0f2855;
  font-weight: 500;
}
.info-sub {
  font-size: 23rpx;
  color: #6b7a91;
  margin-top: 4rpx;
}
.sep {
  height: 1rpx;
  background: #e9eef6;
  margin: 20rpx 0;
}

/* ================ MENU CARD ================ */
.menu-card {
  background: linear-gradient(135deg, #fbf6ec 0%, #f5e8d0 100%);
  border-radius: 32rpx;
  padding: 32rpx 36rpx;
  border: 1rpx solid #e8dcc0;
}
.menu-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #6b4c1e;
  line-height: 1.35;
}
.menu-sub {
  font-size: 24rpx;
  color: #8a6a2e;
  margin-top: 8rpx;
  font-style: italic;
}
.menu-sep {
  height: 1rpx;
  background: #e0d2b0;
  margin: 24rpx 0;
}
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.menu-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.menu-name {
  font-size: 29rpx;
  color: #5a3f14;
  font-weight: 600;
  flex: 1;
}
.menu-tag {
  font-size: 21rpx;
  color: #8a6a2e;
  letter-spacing: 2rpx;
}
.menu-foot {
  font-size: 23rpx;
  color: #8a6a2e;
  margin-top: 24rpx;
  line-height: 1.55;
  font-style: italic;
}

/* ================ WHAT IS DCT ================ */
.dct-head {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}
.dct-logo {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  flex-shrink: 0;
}
.dct-head-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #0f2855;
  line-height: 1.25;
  margin-top: 4rpx;
}
.dct-tagline {
  font-size: 25rpx;
  color: #3d5f94;
  font-style: italic;
  line-height: 1.65;
}
.dct-latin {
  font-size: 23rpx;
  color: #6b7a91;
  margin-top: 12rpx;
  letter-spacing: 0.6rpx;
}
.dct-body {
  font-size: 26rpx;
  color: #2a3d5c;
  margin-top: 28rpx;
  line-height: 1.75;
}
.dct-body-line2 {
  margin-top: 4rpx;
}
.dct-invite {
  font-size: 28rpx;
  color: #1a3a78;
  margin-top: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ================ RULES ENTRY ================ */
.rules-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 28rpx;
  border: 1rpx solid #e3e9f3;
}
.rules-entry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f2855;
}
.rules-entry-sub {
  font-size: 23rpx;
  color: #6b7a91;
  margin-top: 4rpx;
}
.chevron {
  width: 18rpx;
  height: 18rpx;
  border-right: 4rpx solid #a0acc0;
  border-top: 4rpx solid #a0acc0;
  transform: rotate(45deg);
}

/* ================ CTA ================ */
.cta-wrap {
  padding: 48rpx 36rpx 60rpx;
}
.cta {
  width: 100%;
  height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(180deg, #2c5ca0 0%, #1a3a78 100%);
  color: #fff;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
  box-shadow: 0 16rpx 44rpx rgba(26,58,120,0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 0;
}
.cta::after { border: none; }
.cta-hover {
  opacity: 0.92;
  transform: scale(0.99);
}
.cta-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
}
.cta-sub {
  margin-top: 20rpx;
  text-align: center;
  font-size: 23rpx;
  color: #6b7a91;
}
.cta-sub-accent { color: #2c5ca0; }

.tap-hover { background: #f4f7fc; }

/* ================ STAR BULLET (inline) ================ */
.star-bullet {
  width: 20rpx;
  height: 20rpx;
  flex-shrink: 0;
  clip-path: polygon(
    50% 0%, 58% 42%, 100% 50%, 58% 58%,
    50% 100%, 42% 58%, 0% 50%, 42% 42%
  );
}
.star-gold  { background: #c9a24a; }
.star-brown { background: #b8903a; width: 18rpx; height: 18rpx; }
.star-cta   { background: #e9b949; width: 24rpx; height: 24rpx; }
