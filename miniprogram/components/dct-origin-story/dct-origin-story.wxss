.origin-story {
  position: relative;
  overflow: hidden;
  min-height: 1320rpx;
  background:
    linear-gradient(180deg, #ffffff 0 142rpx, #e5e7eb 142rpx 146rpx, transparent 146rpx),
    linear-gradient(180deg, #ffffff 0%, #ffffff 52%, #f3f8fd 100%);
}

.origin-head {
  position: relative;
  z-index: 10;
  height: 142rpx;
  padding: 0 44rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
}

.origin-brand {
  font-size: 25rpx;
  line-height: 1;
  font-weight: 800;
  color: #111827;
}

.origin-time {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #6b7a91;
}

.origin-stage {
  position: relative;
  height: 820rpx;
  overflow: hidden;
}

.origin-stage::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 48rpx;
  height: 620rpx;
  background:
    radial-gradient(circle at 22% 22%, rgba(201, 162, 74, 0.14), transparent 28%),
    radial-gradient(circle at 76% 64%, rgba(15, 40, 85, 0.08), transparent 30%);
  pointer-events: none;
}

.origin-track {
  position: absolute;
  left: 0;
  top: 84rpx;
  width: 5700rpx;
  height: 680rpx;
  transform-origin: 0 50%;
  transition: transform 120ms linear;
}

.origin-rail {
  position: absolute;
  left: 180rpx;
  right: 180rpx;
  top: 360rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(201, 162, 74, 0.42), rgba(15, 40, 85, 0.18), transparent);
}

.origin-glow {
  position: absolute;
  left: 0;
  top: 0;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 243, 191, 0.42) 0%, rgba(255, 243, 191, 0.18) 40%, transparent 72%);
  pointer-events: none;
  transition: transform 120ms linear, opacity 120ms linear;
}

.origin-panel {
  position: absolute;
  width: 584rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #fff8ea;
  border: 1rpx solid rgba(17, 24, 39, 0.08);
  box-shadow: 0 36rpx 82rpx rgba(17, 24, 39, 0.12);
  transition: opacity 180ms linear, filter 180ms linear;
}

.origin-panel-active {
  box-shadow: 0 44rpx 96rpx rgba(15, 40, 85, 0.18);
}

.origin-panel-active .origin-sweep {
  animation: origin-sweep 1180ms ease-out;
}

.origin-panel-img {
  display: block;
  width: 100%;
}

.origin-sweep {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(110deg, transparent 0%, transparent 38%, rgba(255, 255, 255, 0.28) 49%, transparent 60%, transparent 100%);
  transform: translateX(-130%);
  opacity: 0;
  pointer-events: none;
}

.origin-caption {
  position: relative;
  z-index: 5;
  min-height: 300rpx;
  padding: 0 44rpx;
}

.origin-kicker {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 900;
  color: #c9a24a;
  letter-spacing: 8rpx;
  margin-bottom: 22rpx;
  transition: opacity 240ms ease, transform 360ms cubic-bezier(.16, 1, .3, 1);
}

.origin-title {
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 900;
  color: #0f2855;
  transition: opacity 240ms ease, transform 360ms cubic-bezier(.16, 1, .3, 1);
}

.origin-line {
  margin-top: 20rpx;
  color: #2a3d5c;
  font-size: 29rpx;
  line-height: 1.48;
  font-weight: 650;
  transition: opacity 240ms ease, transform 360ms cubic-bezier(.16, 1, .3, 1);
}

.origin-caption-changing .origin-kicker,
.origin-caption-changing .origin-title,
.origin-caption-changing .origin-line {
  opacity: 0;
  transform: translateY(28rpx);
}

.origin-spark {
  position: absolute;
  z-index: 4;
  width: 20rpx;
  height: 20rpx;
  background: #c9a24a;
  clip-path: polygon(50% 0%, 58% 42%, 100% 50%, 58% 58%, 50% 100%, 42% 58%, 0% 50%, 42% 42%);
  opacity: 0.55;
  animation: origin-float 4.8s ease-in-out infinite alternate;
}

.origin-spark-a {
  left: 60rpx;
  top: 58%;
}

.origin-spark-b {
  right: 48rpx;
  top: 22%;
  width: 16rpx;
  height: 16rpx;
  animation-delay: -1.4s;
}

.origin-spark-c {
  right: 64rpx;
  bottom: 300rpx;
  width: 14rpx;
  height: 14rpx;
  animation-delay: -2.6s;
}

.origin-controls {
  position: absolute;
  left: 44rpx;
  right: 44rpx;
  bottom: 28rpx;
  z-index: 12;
  display: grid;
  grid-template-columns: 92rpx 1fr 92rpx;
  align-items: center;
  gap: 26rpx;
}

.origin-control {
  width: 92rpx;
  height: 92rpx;
  padding: 0;
  border: 0;
  border-radius: 50%;
  background: linear-gradient(180deg, #0f2855 0%, #1a3a78 100%);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  box-shadow: 0 20rpx 48rpx rgba(26, 58, 120, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
}

.origin-control::after {
  border: 0;
}

.origin-control-hover {
  opacity: 0.9;
}

.origin-progress {
  height: 8rpx;
  border-radius: 99rpx;
  background: #dce6f2;
  overflow: hidden;
}

.origin-progress-fill {
  width: 0;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #0f2855, #c9a24a);
  transition: width 120ms linear;
}

.origin-opening {
  position: absolute;
  left: 0;
  right: 0;
  top: 146rpx;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 72rpx 52rpx;
  background:
    radial-gradient(circle at 52% 32%, rgba(255, 248, 234, 0.9), transparent 36%),
    linear-gradient(180deg, rgba(255,255,255,0.98), rgba(245,249,253,0.94));
  transition: opacity 640ms ease, transform 640ms cubic-bezier(.16, 1, .3, 1);
}

.origin-opening-hidden {
  opacity: 0;
  transform: scale(1.04);
  pointer-events: none;
}

.origin-opening-inner {
  text-align: center;
}

.origin-opening-kicker {
  color: #c9a24a;
  font-size: 23rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: 7rpx;
  margin-bottom: 30rpx;
}

.origin-opening-title {
  color: #0f2855;
  font-size: 80rpx;
  line-height: 1.04;
  font-weight: 900;
}

.origin-opening-line {
  margin-top: 28rpx;
  color: #2a3d5c;
  font-size: 30rpx;
  line-height: 1.55;
  font-weight: 650;
}

@keyframes origin-sweep {
  0% {
    opacity: 0;
    transform: translateX(-130%);
  }
  20% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: translateX(130%);
  }
}

@keyframes origin-float {
  from {
    transform: translateY(0) rotate(0deg) scale(.9);
  }
  to {
    transform: translateY(-36rpx) rotate(45deg) scale(1.08);
  }
}
